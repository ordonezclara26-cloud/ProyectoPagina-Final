<!DOCTYPE html>
<html>
<head>
<title>Carrito</title>

<style>
body {
    font-family: Arial;
    margin: 0;
    background: #f5f5f5;
}

/* NAVBAR */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 30px;
    background: #111;
    color: white;
}

.logo img {
    height: 40px;
}

.nav-links a {
    color: white;
    margin: 0 10px;
    text-decoration: none;
}

.carrito {
    font-weight: bold;
}

/* CONTENIDO */
.container {
    padding: 30px;
    max-width: 800px;
    margin: auto;
}

.card {
    background: white;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 10px;
}

/* BOTÓN ELIMINAR */
.btn-eliminar {
    background: red;
    color: white;
    border: none;
    padding: 6px 10px;
    border-radius: 5px;
    cursor: pointer;
}

/* TOTAL */
.total-box {
    text-align: center;
    margin-top: 20px;
}

.btn-pagar {
    padding: 12px 20px;
    background: #16a34a;
    color: white;
    border-radius: 8px;
    border: none;
    cursor: pointer;
}

/* BOTÓN VOLVER */
.btn-volver {
    display:inline-block;
    margin-top:15px;
    padding:8px 15px;
    background:black;
    color:white;
    text-decoration:none;
    border-radius:6px;
}
</style>

</head>

<body>

<div class="navbar">

    <div class="logo">
        <img src="/img/logo.png">
    </div>

    <div class="nav-links">
        <a href="/inicio">Inicio</a>
        <a href="/productos">Productos</a>
    </div>

    <div class="carrito">
        🛒 <%= carritoCount %>
    </div>

</div>

<h1 style="text-align:center; margin-top:20px;">
    Tu Carrito de Compras
</h1>

<div class="container">

<% if (productos.length === 0) { %>

    <p style="text-align:center;">Tu carrito está vacío 🛒</p>

<% } else { %>

<% productos.forEach(p => { %>
<div class="card">

    <h3><%= p.nombre %></h3>

<p>Cantidad: <strong><%= p.cantidad %></strong></p>

<p>Precio unitario: L. <%= p.precio %></p>

<p>
Subtotal: 
<strong>L. <%= p.precio * p.cantidad %></strong>
</p>

    <!-- SOLO ELIMINAR -->
    <form action="/carrito/eliminar" method="POST">
        <input type="hidden" name="id" value="<%= p.id %>">
        <button class="btn-eliminar">🗑 Eliminar</button>
    </form>

</div>
<% }) %>

<div class="total-box">
    <h2>Total: L. <%= total %></h2>

    <a href="/checkout">
        <button class="btn-pagar">Proceder a pagar</button>
    </a>

    <br>
</div>

<% } %>

</div>

</body>
</html>