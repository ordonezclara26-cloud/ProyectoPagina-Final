<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soporte Técnico</title>

<style>
body {
    font-family: Arial;
    margin: 0;
    background: #f5f5f5;
}

/* NAVBAR */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    background: #111;
    color: white;
    flex-wrap: wrap;
}

.logo img {
    height: 40px;
}

.nav-links {
    display: flex;
    flex-wrap: wrap;
}

.nav-links a {
    color: white;
    margin: 5px;
    text-decoration: none;
    font-size: 14px;
}

/* TITULO */
h1 {
    text-align: center;
    margin-top: 20px;
}

/* SUBTITULO */
.subtitulo {
    text-align: center;
    max-width: 750px;
    margin: 10px auto 20px;
    color: #555;
    font-size: 16px;
    padding: 0 15px;
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
    padding: 20px;
}

/* CARD */
.card {
    background: #111;
    color: white;
    border-radius: 15px;
    padding: 15px;
    text-align: center;
}

.card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
}

.nombre {
    margin-top: 10px;
    font-weight: bold;
}

/* 📱 RESPONSIVE */
@media (max-width: 768px) {

    .navbar {
        flex-direction: column;
        align-items: flex-start;
    }

    .grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .card img {
        height: 140px;
    }
}
</style>

</head>

<body>

<div class="navbar">
    <div class="logo">
        <img src="/img/logo.png">
    </div>

    <div class="nav-links">
        <a href="/inicio">Inicio</a>
        <a href="/productos">Productos</a>
        <a href="/carrito">Carrito</a>
        <a href="/soporte">Soporte Técnico</a>
        <a href="/ciber">Servicios Múltiples</a>
        <a href="/visas">Visas</a>
    </div>
</div>

<h1>Soporte Técnico</h1>

<div class="subtitulo">
    <p>
        ¿Tu laptop, impresora o equipo presenta fallas? Reparamos pantallas, teclados, impresoras, monitores y UPS con soluciones rápidas y confiables.
    </p>

    <a href="https://wa.me/50494143259?text=Hola,%20quiero%20solicitar%20un%20servicio%20técnico" 
       target="_blank" 
       style="display:block; margin-top:10px; font-weight:bold; color:#25D366; text-align:center; text-decoration:none;">
    
       📞 Escríbenos por WhatsApp para solicitar estos servicios

    </a>
</div>

<div class="grid">

    <div class="card">
        <img src="/img/pantalla.jpg">
        <p class="nombre">Reparación de pantallas dañadas</p>
    </div>

    <div class="card">
        <img src="/img/laptop.jpg">
        <p class="nombre">Mantenimiento de laptops</p>
    </div>

    <div class="card">
        <img src="/img/teclado.jpg">
        <p class="nombre">Cambio de teclado</p>
    </div>

    <div class="card">
        <img src="/img/reparacionimpresora.jpg">
        <p class="nombre">Reparación de impresoras</p>
    </div>

    <div class="card">
        <img src="/img/atasco.jpg">
        <p class="nombre">Solución de atascos</p>
    </div>

    <div class="card">
        <img src="/img/tinta.jpg">
        <p class="nombre">Recarga de tinta</p>
    </div>

    <div class="card">
        <img src="/img/antivirus.jpg">
        <p class="nombre">Instalación de antivirus</p>
    </div>

</div>

</body>
</html>