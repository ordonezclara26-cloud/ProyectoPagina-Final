<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inicio</title>

<style>

/* 🔥 SCROLL SUAVE (AQUÍ VA) */
html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
}

/* NAVBAR */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 20px;
    background: #111;
    color: white;
}

.logo img {
    height: 35px;
}

.nav-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}

.nav-links a {
    color: white;
    margin: 5px;
    text-decoration: none;
    font-weight: bold;
    font-size: 14px;
}

/* HERO */
.hero {
    position: relative;
    height: 100vh;
    background: url('/img/tienda.jpg') center center / cover no-repeat;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* OVERLAY */
.overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
}

/* CONTENIDO */
.hero-content {
    position: relative;
    color: white;
    text-align: center;
    padding: 20px;
    max-width: 90%;
}

.hero h1 {
    font-size: 36px;
    font-weight: bold;
}

.hero p {
    font-size: 16px;
}

/* 🔥 BOTÓN */
.btn-scroll {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 20px;
    background: #007BFF;
    color: white;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
}

/* 🔥 HOVER PRO */
.btn-scroll:hover {
    background: #0056b3;
}

/* INFO */
.info {
    padding: 40px 20px;
    text-align: center;
}

/* CONTACTO */
.contacto {
    background: #111;
    color: white;
    padding: 30px 20px;
    text-align: center;
}

/* RESPONSIVE */
@media (max-width: 768px) {

    .hero h1 {
        font-size: 24px;
    }

    .hero p {
        font-size: 14px;
    }

    .navbar {
        flex-direction: column;
        align-items: flex-start;
    }

    .nav-links {
        margin-top: 10px;
    }
}

</style>

</head>

<body>

<!-- NAVBAR -->
<div class="navbar">

    <div class="logo">
        <img src="/img/logo.png">
    </div>

    <div class="nav-links">
        <a href="/productos">Productos</a>
        <a href="/carrito">Carrito</a>
        <a href="/soporte">Soporte Técnico</a>
        <a href="/ciber">Servicios Múltiples</a>
        <a href="/visas">Visas</a>
    </div>

</div>

<!-- HERO -->
<div class="hero">
    <div class="overlay"></div>

    <div class="hero-content">
        <h1>ENCUENTRA LO QUE NECESITAS</h1>
        <p>Equipos tecnológicos, accesorios y soluciones informáticas en un solo lugar</p>

        <a href="#info" class="btn-scroll">Ver más ↓</a>
    </div>
</div>

<!-- INFO -->
<div class="info" id="info">
    <h2>¿Quiénes somos?</h2>

    <p>
        Sico's es una empresa informática ubicada en Juticalpa, Olancho,
        dedicada a la venta de equipos tecnológicos, accesorios y soporte técnico.
    </p>

    <p>
        Ofrecemos soluciones confiables para estudiantes, empresas y público en general.
    </p>
</div>

<!-- CONTACTO -->
<div class="contacto">
    <h2>Contacto</h2>
    <p>📍 Barrio Belén, Juticalpa, Olancho</p>
    <p>📞 +504 8841-1918</p>
    <p>✉️ sicos6070@gmail.com</p>
</div>

</body>
</html>