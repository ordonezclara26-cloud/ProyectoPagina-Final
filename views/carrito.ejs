<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Carrito</title>
<style>
body {
    font-family: Arial;
    margin: 0;
    background: #f5f5f5;
}

/* NAVBAR */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    background: #111;
    color: white;
    flex-wrap: wrap;
}

.logo img {
    height: 40px;
}

.nav-links {
    display: flex;
    flex-wrap: wrap;
}

.nav-links a {
    color: white;
    margin: 5px;
    text-decoration: none;
}

/* ICONO CARRITO */
.carrito {
    font-weight: bold;
    margin-top: 5px;
}

/* CONTENIDO */
.container {
    padding: 20px;
    max-width: 800px;
    margin: auto;
}

/* CARD */
.card {
    background: white;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 10px;
}

/* BOTÓN ELIMINAR */
.btn-eliminar {
    background: red;
    color: white;
    border: none;
    padding: 6px 10px;
    border-radius: 5px;
    cursor: pointer;
}

/* TOTAL */
.total-box {
    text-align: center;
    margin-top: 20px;
}

.btn-pagar {
    padding: 12px 20px;
    background: #16a34a;
    color: white;
    border-radius: 8px;
    border: none;
    cursor: pointer;
}

/* BOTÓN VOLVER */
.btn-volver {
    display:inline-block;
    margin-top:15px;
    padding:8px 15px;
    background:black;
    color:white;
    text-decoration:none;
    border-radius:6px;
}

/* 📱 RESPONSIVE */
@media (max-width: 768px) {

    .navbar {
        flex-direction: column;
        align-items: flex-start;
    }

    .container {
        padding: 15px;
    }

    .card {
        padding: 12px;
    }

    .btn-pagar {
        width: 100%;
    }
}

/* 🔥 FIX PARA QUE NO SE VEA PEQUEÑO */
html, body {
    width: 100%;
    overflow-x: hidden;
}

/* 🔥 EVITA QUE EL CONTENIDO SE ENCOJA */
.container {
    width: 100%;
    box-sizing: border-box;
}
</style>

</head>

<body>

<div class="navbar">

    <div class="logo">
        <img src="/img/logo.png">
    </div>

    <div class="nav-links">
        <a href="/inicio">Inicio</a>
        <a href="/productos">Productos</a>
    </div>

    <div class="carrito">
        🛒 <%= carritoCount %>
    </div>

</div>

<h1 style="text-align:center;">Tu Carrito de Compras</h1>

<div class="container">

<% if (productos.length === 0) { %>

    <p style="text-align:center;">Tu carrito está vacío 🛒</p>

<% } else { %>

<% productos.forEach(p => { %>
<div class="card">

    <h3><%= p.nombre %></h3>

    <p>Cantidad: <strong><%= p.cantidad %></strong></p>

    <p>Precio unitario: L. <%= p.precio %></p>

    <p>
        Subtotal: 
        <strong>L. <%= p.precio * p.cantidad %></strong>
    </p>

    <form action="/carrito/eliminar" method="POST">
        <input type="hidden" name="id" value="<%= p.id %>">
        <button class="btn-eliminar">🗑 Eliminar</button>
    </form>

</div>
<% }) %>

<div class="total-box">
    <h2>Total: L. <%= total %></h2>

    <a href="/checkout">
        <button class="btn-pagar">Proceder a pagar</button>
    </a>
</div>

<% } %>

</div>

</body>
</html>